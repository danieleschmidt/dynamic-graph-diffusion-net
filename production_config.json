{
  "deployment": {
    "environment": "production",
    "version": "1.0.0",
    "timestamp": "2025-08-26T00:00:00",
    "features": {
      "caching": true,
      "monitoring": true,
      "health_checks": true,
      "load_balancing": true,
      "auto_scaling": true,
      "security": true
    }
  },
  "docker": {
    "image": "dgdn-production:latest",
    "ports": {
      "api": 8080,
      "metrics": 9090,
      "health": 8081
    },
    "resources": {
      "cpu_limit": "2000m",
      "memory_limit": "4Gi",
      "cpu_request": "1000m",
      "memory_request": "2Gi"
    }
  },
  "kubernetes": {
    "namespace": "dgdn-production",
    "replicas": 3,
    "strategy": "RollingUpdate",
    "max_surge": 1,
    "max_unavailable": 0
  },
  "monitoring": {
    "prometheus_enabled": true,
    "grafana_enabled": true,
    "metrics_endpoint": "/metrics",
    "health_endpoint": "/health"
  },
  "scaling": {
    "min_replicas": 2,
    "max_replicas": 10,
    "target_cpu_utilization": 70,
    "target_memory_utilization": 80
  }
}